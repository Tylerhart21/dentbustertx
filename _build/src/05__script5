/* Decorative SVG per service */
function ServiceArt({ id, accent }) {
  const A = accent;
  switch (id) {
    case "hail":
      return (
        <svg viewBox="0 0 400 380" preserveAspectRatio="xMidYMid slice" style={{ width: "100%", height: "100%" }}>
          <defs>
            <radialGradient id="hg1" cx="50%" cy="0%" r="80%">
              <stop offset="0%" stopColor={A} stopOpacity="0.3"/>
              <stop offset="100%" stopColor={A} stopOpacity="0"/>
            </radialGradient>
          </defs>
          <rect width="400" height="380" fill="url(#hg1)"/>
          {Array.from({ length: 60 }).map((_, i) => {
            const x = (i * 41) % 400;
            const y = (i * 67) % 380;
            const r = 2 + (i % 4);
            return <circle key={i} cx={x} cy={y} r={r} fill="rgba(255,255,255,0.12)"/>;
          })}
          {/* Curved panel with dents */}
          <g transform="translate(60, 200)">
            <path d="M0 80 Q140 -10 280 80 L280 100 Q140 30 0 100 Z"
              fill="rgba(255,255,255,0.04)" stroke="rgba(255,255,255,0.15)" strokeWidth="1"/>
            {[40, 80, 120, 160, 200, 240].map((x, i) => (
              <ellipse key={i} cx={x} cy={50 + i * 2} rx={8 + i} ry={3} fill="rgba(0,0,0,0.4)"/>
            ))}
          </g>
        </svg>
      );
    case "ding":
      return (
        <svg viewBox="0 0 400 380" preserveAspectRatio="xMidYMid slice" style={{ width: "100%", height: "100%" }}>
          <defs>
            <linearGradient id="dg1" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stopColor={A} stopOpacity="0.25"/>
              <stop offset="100%" stopColor={A} stopOpacity="0"/>
            </linearGradient>
          </defs>
          <rect width="400" height="380" fill="url(#dg1)"/>
          {/* Two parking spaces */}
          <line x1="100" y1="40" x2="100" y2="340" stroke="rgba(255,255,255,.18)" strokeWidth="3"/>
          <line x1="300" y1="40" x2="300" y2="340" stroke="rgba(255,255,255,.18)" strokeWidth="3"/>
          <line x1="200" y1="40" x2="200" y2="340" stroke={A} strokeWidth="3" strokeDasharray="8 6"/>
          {/* Two cars */}
          {[60, 240].map((x, i) => (
            <g key={i} transform={`translate(${x}, 150)`}>
              <rect x="0" y="0" width="100" height="80" rx="12" fill="rgba(255,255,255,.08)" stroke="rgba(255,255,255,.2)"/>
              <rect x="10" y="15" width="80" height="25" rx="6" fill="rgba(255,255,255,.06)"/>
            </g>
          ))}
          {/* Ding indicator */}
          <circle cx="200" cy="200" r="20" fill={A} opacity="0.7"/>
          <circle cx="200" cy="200" r="40" fill="none" stroke={A} strokeWidth="1.5" opacity="0.4"/>
          <circle cx="200" cy="200" r="60" fill="none" stroke={A} strokeWidth="1.5" opacity="0.2"/>
        </svg>
      );
    case "pdr":
      return (
        <svg viewBox="0 0 400 380" preserveAspectRatio="xMidYMid slice" style={{ width: "100%", height: "100%" }}>
          <defs>
            <radialGradient id="pg1" cx="50%" cy="50%" r="70%">
              <stop offset="0%" stopColor={A} stopOpacity="0.25"/>
              <stop offset="100%" stopColor={A} stopOpacity="0"/>
            </radialGradient>
          </defs>
          <rect width="400" height="380" fill="url(#pg1)"/>
          {/* Reflection grid */}
          {Array.from({ length: 10 }).map((_, i) => (
            <line key={i} x1="0" y1={40 + i * 32} x2="400" y2={40 + i * 32}
              stroke={A} strokeWidth="1" opacity="0.18"/>
          ))}
          {/* Tool */}
          <g transform="translate(160, 110)">
            <rect x="0" y="0" width="14" height="200" rx="6" fill="rgba(255,255,255,.7)" />
            <circle cx="7" cy="0" r="14" fill={A} stroke="rgba(255,255,255,.4)" strokeWidth="2"/>
            <rect x="-6" y="200" width="26" height="14" rx="4" fill="rgba(120,120,120,.7)"/>
          </g>
          {/* Dent profile */}
          <path d="M40 280 Q200 240 360 280" fill="none" stroke="rgba(255,255,255,.4)" strokeWidth="2"/>
          <path d="M40 280 Q200 320 360 280" fill="rgba(255,255,255,.05)" stroke={A} strokeWidth="1.5" strokeDasharray="4 4"/>
        </svg>
      );
    case "ceramic":
      return (
        <svg viewBox="0 0 400 380" preserveAspectRatio="xMidYMid slice" style={{ width: "100%", height: "100%" }}>
          <defs>
            <linearGradient id="cg1" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stopColor="rgba(255,255,255,0.15)"/>
              <stop offset="50%" stopColor={A} stopOpacity="0.4"/>
              <stop offset="100%" stopColor="rgba(255,255,255,0)"/>
            </linearGradient>
          </defs>
          <rect width="400" height="380" fill="rgba(15,18,25,1)"/>
          <rect width="400" height="380" fill="url(#cg1)"/>
          {/* Water droplets */}
          {Array.from({ length: 18 }).map((_, i) => {
            const x = ((i * 79) % 400);
            const y = ((i * 53) % 380);
            const r = 8 + (i % 5) * 3;
            return (
              <g key={i}>
                <circle cx={x} cy={y} r={r} fill="rgba(255,255,255,0.06)" stroke="rgba(255,255,255,0.25)" strokeWidth="1"/>
                <circle cx={x - r/3} cy={y - r/3} r={r/4} fill="rgba(255,255,255,0.35)"/>
              </g>
            );
          })}
          {/* Sparkle */}
          <g transform="translate(200, 190)" stroke={A} strokeWidth="2" fill="none">
            <path d="M0 -30 L0 30 M-30 0 L30 0"/>
            <path d="M-21 -21 L21 21 M-21 21 L21 -21" opacity="0.6"/>
          </g>
        </svg>
      );
    case "delivery":
      return (
        <svg viewBox="0 0 400 380" preserveAspectRatio="xMidYMid slice" style={{ width: "100%", height: "100%" }}>
          <defs>
            <linearGradient id="tg1" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stopColor={A} stopOpacity="0.2"/>
              <stop offset="100%" stopColor={A} stopOpacity="0"/>
            </linearGradient>
          </defs>
          <rect width="400" height="380" fill="url(#tg1)"/>
          {/* Road */}
          <rect x="0" y="280" width="400" height="100" fill="rgba(255,255,255,.05)"/>
          <line x1="0" y1="330" x2="400" y2="330" stroke={A} strokeDasharray="30 20" strokeWidth="3"/>
          {/* Truck */}
          <g transform="translate(80, 180)">
            <rect x="0" y="0" width="150" height="90" rx="6" fill="rgba(255,255,255,.1)" stroke="rgba(255,255,255,.25)"/>
            <rect x="150" y="30" width="60" height="60" rx="6" fill="rgba(255,255,255,.15)" stroke="rgba(255,255,255,.3)"/>
            <rect x="158" y="40" width="44" height="22" rx="3" fill="rgba(255,255,255,.4)"/>
            <circle cx="40" cy="100" r="16" fill="#0a0c11" stroke={A} strokeWidth="3"/>
            <circle cx="170" cy="100" r="16" fill="#0a0c11" stroke={A} strokeWidth="3"/>
          </g>
          {/* Speed lines */}
          {[120, 140, 160].map((y, i) => (
            <line key={i} x1="0" y1={y} x2={60 - i * 10} y2={y}
              stroke={A} strokeWidth="2" opacity={0.5 - i * 0.1}/>
          ))}
        </svg>
      );
    default:
      return null;
  }
}

